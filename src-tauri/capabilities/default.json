{
  "identifier": "default",
  "description": "Default permissions for FlowState",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "open-shortcuts",
          "cmd": "open",
          "args": ["-a", "Shortcuts"]
        }
      ]
    },
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "dialog:default",
    "dialog:allow-open",
    "updater:default"
  ]
}